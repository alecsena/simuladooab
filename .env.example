# Backend - copie para .env e ajuste os valores em produção

# Elasticsearch
ES_HOST=elasticsearch:9200

# MongoDB
MONGO_URI=mongodb://mongodb:27017/oab_simulado

# JWT
JWT_SECRET=troque_este_segredo_em_producao
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Usuário admin inicial (criado no primeiro start)
ADMIN_EMAIL=admin@oab.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrador

# Diretório com o JSON de questões (montado no container)
DATA_DIR=/data/questoes

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
